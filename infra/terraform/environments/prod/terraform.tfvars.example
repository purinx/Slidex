project_name       = "slidex"
environment        = "prod"
aws_region         = "ap-northeast-1"
slides_bucket_name = "slidex-prod-slides-example"
slides_prefix      = "decks"

amplify_repository  = "https://github.com/example/slidex"
amplify_branch_name = "main"

# Prefer connecting GitHub from the Amplify Console or CI instead of storing a token in Terraform state.
# amplify_access_token = "github_pat_..."

# domain_name       = "slides.example.com"
# sub_domain_prefix = ""

upload_max_file_size_mb = 20
upload_max_deck_size_mb = 200
ogp_default_image_url   = ""

cors_allowed_origins = []
