project_name = "slidex"
environment  = "prod"
aws_region   = "ap-northeast-1"

# By default bucket names are generated as:
# slidex-prod-<aws-account-id>-frontend
# slidex-prod-<aws-account-id>-slides
# frontend_bucket_name = "slidex-prod-frontend-example"
# slides_bucket_name   = "slidex-prod-slides-example"

slides_prefix = "decks"

upload_max_file_size_mb = 20
upload_max_deck_size_mb = 200
ogp_default_image_url   = ""

# The browser uploads slide files directly to S3 presigned URLs.
# Use ["*"] for the default CloudFront domain, or replace with your custom origin.
cors_allowed_origins = ["*"]

force_destroy_frontend_bucket = true
force_destroy_slide_bucket    = false

lambda_memory_size      = 512
lambda_timeout_seconds  = 30
cloudfront_price_class  = "PriceClass_200"
