project_name       = "slidex"
environment        = "prod"
aws_region         = "ap-northeast-1"
slides_prefix      = "decks"

amplify_branch_name = "main"

# By default the bucket name is generated as:
# slidex-prod-<aws-account-id>-slides
# slides_bucket_name = "slidex-prod-slides-example"

# To connect GitHub during Terraform apply, set both values below.
# Otherwise, connect the repository later from the Amplify Console.
# Note: access tokens are stored in Terraform state.
# amplify_repository   = "https://github.com/purinx/Slidex"
# amplify_access_token = "github_pat_..."

# domain_name       = "slides.example.com"
# sub_domain_prefix = ""

upload_max_file_size_mb = 20
upload_max_deck_size_mb = 200
ogp_default_image_url   = ""

cors_allowed_origins = []
